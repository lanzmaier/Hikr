{
  "name": "hikr-mobile",
  "version": "1.0.0",
  "description": "Hikr Mobile Frontend - React Native with TypeScript",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext ts,tsx",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "eject": "expo eject",
    "generate:api": "openapi-generator-cli generate -i ../shared-resources/api-contracts/openapi.yaml -g typescript-axios -o src/generated/api"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "expo": "^50.0.0",
    "expo-status-bar": "^1.11.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/stack": "^6.3.0",
    "react-native-screens": "^3.27.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-gesture-handler": "^2.13.0",
    "axios": "^1.6.0",
    "@tanstack/react-query": "^5.25.0",
    "zustand": "^4.4.0",
    "react-native-paper": "^5.10.0",
    "react-native-vector-icons": "^10.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.4.0",
    "@openapitools/openapi-generator-cli": "^2.13.0",
    "expo-cli": "^6.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
