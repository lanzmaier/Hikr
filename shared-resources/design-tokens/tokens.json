{
  "colors": {
    "primary": "#2E7D32",
    "primary_dark": "#1B5E20",
    "primary_light": "#A5D6A7",
    "secondary": "#FF6F00",
    "secondary_dark": "#E65100",
    "secondary_light": "#FFB74D",
    "accent": "#1976D2",
    "success": "#4CAF50",
    "warning": "#FFC107",
    "error": "#F44336",
    "neutral": "#424242",
    "neutral_light": "#BDBDBD",
    "background": "#FFFFFF",
    "surface": "#F5F5F5",
    "text_primary": "#212121",
    "text_secondary": "#757575"
  },
  "typography": {
    "fontFamily": "'Roboto', sans-serif",
    "baseFontSize": 16,
    "headings": {
      "h1": {
        "fontSize": 32,
        "fontWeight": 700,
        "lineHeight": 1.2
      },
      "h2": {
        "fontSize": 28,
        "fontWeight": 700,
        "lineHeight": 1.3
      },
      "h3": {
        "fontSize": 24,
        "fontWeight": 600,
        "lineHeight": 1.4
      },
      "h4": {
        "fontSize": 20,
        "fontWeight": 600,
        "lineHeight": 1.4
      }
    },
    "body": {
      "regular": {
        "fontSize": 16,
        "fontWeight": 400,
        "lineHeight": 1.5
      },
      "small": {
        "fontSize": 14,
        "fontWeight": 400,
        "lineHeight": 1.5
      },
      "large": {
        "fontSize": 18,
        "fontWeight": 400,
        "lineHeight": 1.5
      }
    }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48
  },
  "borderRadius": {
    "none": 0,
    "sm": 4,
    "md": 8,
    "lg": 12,
    "xl": 16,
    "full": 9999
  },
  "shadows": {
    "none": "none",
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1)"
  }
}
